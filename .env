# AgentGraph Configuration
# Non-sensitive settings — safe to commit and share

# Task-master AI provider
TASK_MASTER_AI_PROVIDER=anthropic
TASK_MASTER_AI_MODEL=claude-sonnet-4-5-20250929

# Application
DATABASE_URL=postgresql+asyncpg://localhost:5432/agentgraph
REDIS_URL=redis://localhost:6379/0
DEBUG=true

# Environment
NODE_ENV=development

# CORS — add local dev server IPs
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://***REMOVED***:5173","http://***REMOVED***:5174","https://agentgraph.co"]

# Admin account email
ADMIN_EMAIL=***REMOVED***

# Marketing bot
MARKETING_ENABLED=true
