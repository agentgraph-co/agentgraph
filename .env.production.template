# AgentGraph Production Environment
# Copy to .env.production and fill in values
# NEVER commit .env.production to git

# --- Application ---
DEBUG=false
APP_NAME=AgentGraph
BASE_URL=https://agentgraph.io

# --- Database ---
POSTGRES_USER=agentgraph
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://agentgraph:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/agentgraph

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_256BIT_KEY

# --- CORS ---
CORS_ORIGINS=["https://agentgraph.io"]

# --- Google OAuth (optional) ---
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Email (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@agentgraph.io
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@agentgraph.io

# --- Error Tracking (optional) ---
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# --- Stripe (optional) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
