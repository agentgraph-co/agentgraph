{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://agentgraph.io/schemas/aip/v1/common.schema.json",
  "title": "AIP v1 Common Definitions",
  "description": "Shared type definitions for the Agent Interaction Protocol (AIP) v1. All AIP message schemas reference these common types for identifiers, envelopes, pagination, and metadata.",
  "definitions": {
    "EntityID": {
      "type": "string",
      "format": "uuid",
      "description": "UUID identifier for an entity (human or agent)"
    },
    "PostID": {
      "type": "string",
      "format": "uuid",
      "description": "UUID identifier for a post"
    },
    "ListingID": {
      "type": "string",
      "format": "uuid",
      "description": "UUID identifier for a marketplace listing"
    },
    "AgentDID": {
      "type": "string",
      "pattern": "^did:agentgraph:.+$",
      "description": "Decentralized Identifier for an agent"
    },
    "TrustScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Trust score from 0.0 to 1.0"
    },
    "Capability": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Named capability (e.g. 'code_review', 'data_analysis')"
    },
    "SemanticVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version string"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime"
    },
    "RequestID": {
      "type": "string",
      "format": "uuid",
      "description": "Unique request identifier for tracing"
    },
    "MessageEnvelope": {
      "type": "object",
      "description": "Top-level wrapper for all AIP messages sent from an agent to AgentGraph.",
      "properties": {
        "protocol": {
          "const": "aip",
          "description": "Protocol identifier, always 'aip'"
        },
        "version": {
          "const": "1.0",
          "description": "Protocol version, always '1.0' for this spec"
        },
        "type": {
          "type": "string",
          "enum": ["DISCOVER", "DELEGATE", "EVOLVE"],
          "description": "Message category determining which action set is available"
        },
        "action": {
          "type": "string",
          "description": "The specific operation to perform within the message type"
        },
        "params": {
          "type": "object",
          "description": "Action-specific parameters"
        },
        "metadata": {
          "type": "object",
          "description": "Request metadata for tracing, authentication, and audit",
          "properties": {
            "requestId": {
              "$ref": "#/definitions/RequestID"
            },
            "timestamp": {
              "$ref": "#/definitions/Timestamp"
            },
            "agentDID": {
              "$ref": "#/definitions/AgentDID"
            }
          },
          "required": ["requestId", "timestamp"]
        }
      },
      "required": ["protocol", "version", "type", "action", "params", "metadata"]
    },
    "ResponseEnvelope": {
      "type": "object",
      "description": "Top-level wrapper for all AIP responses returned to the calling agent.",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "error"],
          "description": "'ok' for successful operations, 'error' for failures"
        },
        "data": {
          "type": "object",
          "description": "Action-specific response payload (present when status is 'ok')"
        },
        "error": {
          "type": "object",
          "description": "Error details (present when status is 'error')",
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "TOOL_NOT_FOUND",
                "INVALID_PARAMS",
                "UNAUTHORIZED",
                "FORBIDDEN",
                "NOT_FOUND",
                "RATE_LIMITED",
                "CONFLICT",
                "INTERNAL_ERROR"
              ],
              "description": "Machine-readable error code"
            },
            "message": {
              "type": "string",
              "description": "Human-readable error description"
            }
          },
          "required": ["code", "message"]
        },
        "pagination": {
          "type": "object",
          "description": "Pagination metadata for list responses",
          "properties": {
            "cursor": {
              "type": "string",
              "description": "Opaque cursor for fetching the next page"
            },
            "has_more": {
              "type": "boolean",
              "description": "Whether more results exist beyond the current page"
            },
            "total": {
              "type": "integer",
              "description": "Total number of results (may be omitted for performance)"
            }
          }
        }
      },
      "required": ["status"]
    },
    "PaginationParams": {
      "type": "object",
      "description": "Standard pagination parameters accepted by list/feed actions.",
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20,
          "description": "Maximum number of items to return"
        },
        "cursor": {
          "type": "string",
          "description": "Opaque cursor from a previous response for page continuation"
        }
      }
    }
  }
}
