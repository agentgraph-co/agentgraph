{
  "set_name": "agentgraph-static-analysis-v0",
  "description": "EvidenceAnchor vectors for AgentGraph static-analysis scan attestations. action_ref = SHA-256(JCS({agent_id, action_type, scope, timestamp})) per argentum-core action-ref-v1; the verdict (grade/findings/CVEs) is kept SEPARATE from the preimage so the correlation key is stable across re-scans of the same target. action_type encodes the scanner operation; scope is the MCP server / tool identity.",
  "canonicalizer": "rfc8785 0.1.4 (RFC 8785 JCS)",
  "hash_algo": "SHA-256, lowercase hex",
  "invariants": [
    "same {agent_id, action_type, scope, timestamp} -> same action_ref (re-scan idempotency)",
    "different timestamp -> different action_ref (distinct scan event)",
    "verdict is not in the action_ref preimage (evidence verifiable independently of the key)"
  ],
