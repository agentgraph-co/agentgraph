{
  "schema_version": "1.0",
  "artefact_id": "x402-safety-screen-conformance-v0",
  "plugin": {
    "name": "agentgraph.safety",
    "version": "v0",
    "declares": [
      "resource_url",
      "safety_attestation"
    ],
    "interface": "screen(input, ctx) -> {verdict: admit|deny, reason?, entities?}",
    "properties": [
      "deny-only",
      "mutation-free",
      "keys_off_raw: resource_url+safety_attestation"
    ]
  },
  "canonicalizer": "rfc8785 0.1.4 (RFC 8785 JCS)",
  "hash": "SHA-256, lowercase hex (over JCS of the verdict object)",
  "derivation": "For each vector, run the reference safety_screen.screen(input, ctx); the verdict object is canonicalized with RFC 8785 and SHA-256ed. A conforming implementation MUST reproduce verdict_canonical_bytes_utf8 and verdict_sha256 exactly.",
  "vectors": [
    {
      "name": "admit_clean",
      "input": {
        "resource_url": "https://api.example.com/x402",
        "safety_attestation": {
          "type": "TrustAttestation",
          "version": "0.3.3",
          "claim_type": "authority",
          "subject": {
            "resource_url": "https://api.example.com/x402"
          },
          "attestation": {
            "type": "SecurityAttestation",
            "confidence": 0.9,
            "payload": {
              "grade": "A",
              "trust_score": 95,
              "findings": {
                "critical": 0,
                "high": 0,
                "medium": 1,
                "total": 1
              }
            }
          }
        }
      },
      "ctx": {},
      "expected_verdict": {
        "verdict": "admit"
      },
      "verdict_canonical_bytes_utf8": "{\"verdict\":\"admit\"}",
      "verdict_sha256": "47978ae01a507908f79bcc5cdebf659da2cab6078ebb9abad94d81aa20b6d20c"
    },
    {
