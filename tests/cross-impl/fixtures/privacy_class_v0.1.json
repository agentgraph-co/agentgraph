  "v01_additions": {
    "purpose": "v0.1 adds three vectors targeting field-name canonicalisation discipline — the gap @Ilya0527 identified on x402#2326 (2026-05-21). v0's 007a/007b/007c pair conflates field-name and value-form differences; v0.1 isolates field-name discipline alone via 007d, and generalises it to a second field (block_height) via the 008a/008b pair. Two pairs documenting one rule matches the AP2 #265 structural discipline.",
    "new_invariant": "field_name_canonicalisation",
    "new_vectors": [
      "privacy-class-v0.1-timestamp-007d-renamed-field",
      "privacy-class-v0.1-block-height-008a-canonical-name",
      "privacy-class-v0.1-block-height-008b-legacy-name"
    ],
    "new_pair_invariants": [
      "007d-renamed-field MUST differ from 007a (value identical, field name different)",
      "008a-canonical-name MUST differ from 008b-legacy-name (value identical, field name different)"
    ],
    "compatibility": "Additive only. The 10 v0 vectors stay byte-identical with the same expected hashes. Implementations passing v0 also pass v0.1 for those 10 vectors; the 3 new v0.1 vectors test the new invariant. v0 artefact remains published unchanged."
  },
  "context": {
    "verification_recipe": [
      "1. For each vector, take attestation_body verbatim.",
      "2. Canonicalise with RFC 8785 (any conformant impl).",
      "3. base64-encode the JCS bytes; MUST equal expected_jcs_bytes_b64.",
      "4. SHA-256 the JCS bytes, lowercase hex; MUST equal expected_privacy_class_hash.",
      "5. Honour pair expectations: same_hash_as / different_hash_from MUST hold."
    ],
    "pair_semantics": {
      "object_key_order": "MUST be hash-identical (JCS sorts object keys)",
      "array_order": "MUST differ (JCS preserves array order)",
      "optional_fields": "MUST differ (presence != absence)",
      "scalar_form": "MUST differ (string '12345678' != integer 12345678)",
      "unicode_normalisation": "MUST differ (RFC 8785 does no Unicode normalisation)",
      "timestamp_lexical": "MUST differ (timestamp_ms int / RFC3339 string / RFC3339-ms string all distinct under JCS)",
      "field_name_canonicalisation": "MUST differ (same value, different field name produces different JCS bytes; JCS treats field names as opaque)"
    }
  },
