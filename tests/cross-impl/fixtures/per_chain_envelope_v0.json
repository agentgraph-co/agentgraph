  "anchored_to": {
    "purpose": "Per-chain envelope conformance vectors covering canonicalisation edge cases that surface at the chain-identifier and chain-native-value layers, distinct from the application-mandate layer (AP2 OMH v0) or attestation layer (privacy_class). 19 vectors across 7 chain families test the chain-specific JCS interactions an implementation needs to handle correctly to produce byte-identical canonical output across the multi-chain agentic-payment surface.",
    "related": [
      "https://gist.github.com/chopmob-cloud/1dca25fd6107db4b7a30bed5dbf2ded8",
      "https://gist.github.com/chopmob-cloud/30bcbc717c86493f737feb92c415ba07",
      "https://gist.github.com/chopmob-cloud/5f35eaa527d292bf3ddc52f8725a85c9"
    ],
    "shared_canonicalisation_thread": "https://github.com/x402-foundation/x402/issues/2326"
  },
  "derivation": "per_chain_envelope_hash = SHA-256(JCS_RFC8785(mandate_body)). Same JCS+SHA-256 substrate as the AP2 OMH v0, privacy_class, and CTEF/APS vector sets; the per-chain dimension stresses chain-specific scalar shapes, address-form canonicalisation, and chain-native amount precision rather than top-level mandate structure.",
  "context": {
    "verification_recipe": [
      "1. For each vector, take mandate_body verbatim.",
      "2. Canonicalise with RFC 8785 (any conformant impl).",
      "3. base64-encode the JCS bytes; MUST equal expected_jcs_bytes_b64.",
      "4. SHA-256 the JCS bytes, lowercase hex; MUST equal expected_per_chain_envelope_hash.",
      "5. Honour pair invariant relations; the 9 declared pair invariants are summarised in the pair_invariants block below."
    ],
    "per_chain_invariants_tested": {
      "algorand": "ASA-id type (integer vs string-coerced); address canonical form",
      "voi": "amount type (microunits int vs string)",
      "hedera": "account/token-id lexical form (no leading zeros); HTS allowance key-order",
      "stellar": "SAC contract-id case sensitivity; 7-dp amount precision (trailing zero vs no trailing)",
      "base": "EIP-55 checksum vs lowercase EVM addresses",
      "solana": "mint base58 case sensitivity; ATA vs wallet address distinction",
      "tempo": "EIP-55 checksum vs lowercase (EVM-derived L1)"
    }
  },
